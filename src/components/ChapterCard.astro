---
import type { Chapter } from '../config/site';

interface Props {
    chapter: Chapter;
}

const { chapter } = Astro.props;
---

<a href={`/chapters/${chapter.slug}`} class="card group block no-underline">
    <div class="mb-3 flex items-center gap-3">
        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-lg font-bold text-white">
            {chapter.number}
        </span>
        <h3 class="text-lg font-bold text-white group-hover:text-accent-warm">{chapter.title}</h3>
    </div>
    <p class="mb-3 text-sm text-white/70">{chapter.description}</p>
    <p class="text-xs text-accent-warm/80">{chapter.bistuContext}</p>
    <span class="mt-4 inline-block text-sm font-medium text-primary group-hover:text-accent-warm">阅读本章 →</span>
</a>
