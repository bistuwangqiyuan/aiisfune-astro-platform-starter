---
import { site } from '../config/site';

interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['rounded-lg border border-primary/30 bg-primary/10 px-6 py-4 text-center', className]}>
    <p class="text-lg font-bold tracking-widest text-white sm:text-xl">
        「{site.motto}」
    </p>
    <p class="mt-1 text-sm text-white/60">{site.name} · 校庆日 {site.anniversary}</p>
</div>
