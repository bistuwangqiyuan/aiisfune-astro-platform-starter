---
import { site } from '../config/site';
---

<div class="program-banner -mx-6 mb-2 px-6 py-2.5 sm:-mx-12 sm:px-12">
    <div class="flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
        <p class="program-badge inline-flex w-fit items-center gap-2 text-sm font-bold sm:text-base">
            <span>{site.internshipProgram}</span>
            <span class="text-white/50">·</span>
            <span>{site.aiProgramming}</span>
        </p>
        <p class="text-xs text-white/70 sm:text-sm">
            {site.name} · {site.courseName}
        </p>
    </div>
</div>

<style>
    .program-banner {
        background: linear-gradient(90deg, color-mix(in oklab, var(--color-primary) 90%, transparent), color-mix(in oklab, var(--color-complementary) 95%, transparent));
        border-bottom: 2px solid color-mix(in oklab, var(--color-accent-warm) 60%, transparent);
    }
</style>
