---
import { site } from '../config/site';

interface Props {
    showText?: boolean;
}

const { showText = true } = Astro.props;
---

<div class="flex items-center gap-3">
    <img
        src="/images/bistu-logo.png"
        alt={`${site.name}校徽`}
        width="48"
        height="48"
        class="h-10 w-10 object-contain sm:h-12 sm:w-12"
    />
    {
        showText && (
            <div class="hidden sm:block">
                <div class="text-sm font-bold leading-tight text-white">{site.shortName}</div>
                <div class="text-xs leading-tight text-white/70">{site.courseName}</div>
                <div class="program-badge mt-1 text-[10px] font-semibold leading-tight">{site.programTagline}</div>
            </div>
        )
    }
</div>
