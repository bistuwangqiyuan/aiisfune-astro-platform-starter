---
import Logo from './Logo.astro';
import { navItems, site } from '../config/site';

const currentPath = Astro.url.pathname;
---

<nav class="flex flex-wrap items-center justify-between gap-4 pt-4 pb-12 sm:pt-6 sm:pb-16">
    <div class="flex flex-col gap-2">
        <a href="/" class="no-underline">
            <Logo />
        </a>
        <p class="program-badge w-fit text-xs sm:hidden">{site.programTagline}</p>
    </div>
    <ul class="flex flex-wrap gap-x-1 gap-y-1 sm:gap-x-2">
        {
            navItems.map((item) => {
                const isActive =
                    item.href === '/'
                        ? currentPath === '/'
                        : currentPath.startsWith(item.href);
                return (
                    <li>
                        <a
                            href={item.href}
                            class:list={[
                                'nav-link inline-block rounded-md px-2 py-1.5 text-sm no-underline transition sm:px-3 sm:py-2 sm:text-base',
                                isActive
                                    ? 'bg-primary/30 font-semibold text-white'
                                    : 'text-white/80 hover:bg-white/10 hover:text-white'
                            ]}
                        >
                            {item.linkText}
                        </a>
                    </li>
                );
            })
        }
    </ul>
</nav>
