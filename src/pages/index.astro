---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MottoBanner from '../components/MottoBanner.astro';
import ChapterCard from '../components/ChapterCard.astro';
import { site, courseHighlights, chapters } from '../config/site';
---

<Layout title={site.courseName}>
    <Hero />

    <section class="mb-16">
        <h2 class="section-title">课程亮点</h2>
        <div class="grid gap-6 sm:grid-cols-3">
            {
                courseHighlights.map((item) => (
                    <div class="card">
                        <h3 class="mb-2 text-lg font-bold text-accent-warm">{item.title}</h3>
                        <p class="text-sm text-white/70">{item.description}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="mb-16">
        <div class="mb-8 flex items-end justify-between">
            <h2 class="section-title mb-0">课程章节</h2>
            <a href="/chapters" class="text-sm text-accent-warm no-underline hover:opacity-80">查看全部 →</a>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
            {chapters.slice(0, 4).map((chapter) => <ChapterCard chapter={chapter} />)}
        </div>
    </section>

    <MottoBanner class="mb-8" />

    <section class="card">
        <h2 class="mb-4 text-xl font-bold">关于本课程</h2>
        <p class="mb-4 text-white/80">
            {site.name}（{site.abbreviation}）是北京市重点支持建设的信息学科较为齐全的高校，2021
            年获批博士学位授予单位。本网站为「{site.programTagline}」项目下的{site.courseName}学习平台，面向全体本科生培养 AI 素养与编程实践能力。
        </p>
        <a href="/about" class="btn no-underline">了解更多学校信息</a>
    </section>
</Layout>
